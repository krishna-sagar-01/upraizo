---
const features = [
  {
    title: "Expert Mentorship",
    description:
      "Learn directly from a master mentor with deep industry expertise. Get actionable feedback that propels your career forward.",
    // Standard Shield Icon
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />',
    gridClass: "md:col-span-1 lg:col-span-1",
  },
  {
    title: "Lifetime Access & Updates",
    description:
      "Study at your own pace with unlimited lifetime access to all course modules, exclusive resources, and future updates. Revisit the material whenever you need a refresher, ensuring your skills stay sharp and relevant in an ever-evolving digital landscape. No hidden fees, no expiration dates—just pure value.",
    // Standard Clock Icon
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
    gridClass: "md:col-span-1 lg:col-span-2",
  },
  {
    title: "Real Career Transformation",
    description:
      "Go beyond basic theory with actionable, project-based steps designed for your personal and professional growth. Our curriculum is engineered to challenge your limits, helping you build a robust portfolio and the hands-on experience required to stand out to top-tier employers, secure promotions, or launch your own successful venture.",
    // Standard Zap/Lightning Icon
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
    gridClass: "md:col-span-1 lg:col-span-2",
  },
  {
    title: "Personal Confidence",
    description:
      "Build the soft skills, communication tactics, and inner confidence needed to excel in any high-stakes situation.",
    // Standard User Icon (Perfect shape with circle + path)
    icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
    gridClass: "md:col-span-1 lg:col-span-1",
  },
];
---

<section id="features" class="py-24 border-t border-zinc-200 dark:border-zinc-800 cursor-default">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <h2
        class="text-xs font-black text-red-600 uppercase tracking-[0.3em] mb-4"
      >
        Why Choose Upraizo
      </h2>
      <h3
        class="text-4xl lg:text-5xl font-black text-zinc-900 dark:text-white mb-6"
      >
        Built for your growth
      </h3>
      <p
        class="max-w-2xl mx-auto text-lg text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed"
      >
        We provide more than just video lessons. We provide a structured path to
        true personal and professional excellence.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        features.map((feature) => (
          <div
            class={`p-8 lg:p-10 rounded-3xl bg-zinc-50/50 dark:bg-zinc-900/40 border border-zinc-200 dark:border-zinc-800/80 transition-all duration-300 hover:shadow-xl hover:shadow-zinc-200/50 dark:hover:shadow-black/50 hover:-translate-y-1 group flex flex-col justify-start ${feature.gridClass}`}
          >
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-8 transition-transform group-hover:scale-110 duration-300 ease-out bg-zinc-200 dark:bg-zinc-700 text-zinc-900 dark:text-zinc-100">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="26"
                height="26"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={feature.icon}
              />
            </div>

            <h4 class="text-2xl font-bold text-zinc-900 dark:text-white mb-4 tracking-tight">
              {feature.title}
            </h4>
            <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-medium text-base lg:text-lg">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
