---
import CourseList from "../courses/CourseList.astro";
---

<section
  id="courses"
  class="py-24 border-t border-zinc-200 dark:border-zinc-800"
>
  <div class="text-center mb-20">
    <h2 class="text-xs font-black text-red-600 uppercase tracking-[0.3em] mb-4">
      Our Course
    </h2>
    <h3
      class="text-4xl lg:text-5xl font-black text-zinc-900 dark:text-white mb-6"
    >
      Transform Your Potential into Proficiency
    </h3>
    <p
      class="max-w-2xl mx-auto text-lg text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed"
    >
      Move beyond passive video watching. Our LMS provides a rigorous, structured roadmap and hands-on projects to ensure you dominate your industry.
    </p>
  </div>

  <CourseList />
</section>
