---
const faqs = [
  {
    question: "What exactly are Soft Skills, and why do I need them?",
    answer: "Soft skills are personal attributes like communication, leadership, and emotional intelligence. In today's competitive world, these skills are essential for career growth and building meaningful professional relationships."
  },
  {
    question: "What is the validity of the course content?",
    answer: "The validity varies by course, but we guarantee a minimum of 1 year (12 months) of validity for every course, so you can learn comfortably at your own pace."
  },
  {
    question: "How do I get support if I have doubts?",
    answer: "We provide dedicated ticket-based support. If you have any issues or doubts, you can raise a support ticket and our team will resolve it as quickly as possible."
  },
  {
    question: "Can I interact directly with the master mentor?",
    answer: "Yes, we provide periodic Q&A sessions and dedicated community groups where you can get direct feedback and guidance from the master mentor."
  },
  {
    question: "Are there any prerequisites for joining these courses?",
    answer: "No, there are no special technical background prerequisites for these courses. If you have a passion for learning and a desire to grow, you are welcome to join."
  }
];
---

<section id="faq" class="pt-24 border-t border-zinc-200 dark:border-zinc-800">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-xs font-black text-red-500 uppercase tracking-[0.3em] mb-4">Support & FAQ</h2>
      <h3 class="text-4xl lg:text-5xl font-black text-zinc-900 dark:text-white mb-6">Frequently Asked Questions</h3>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 font-medium">
        Find answers to all your important questions here.
      </p>
    </div>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="faq-item group border border-zinc-200 dark:border-zinc-800 rounded-4xl overflow-hidden transition-all duration-300 bg-zinc-50 dark:bg-zinc-900/50">
          <button 
            class="faq-trigger w-full px-6 md:px-8 py-6 flex items-center justify-between gap-4 text-left focus:outline-none"
            aria-expanded="false"
          >
            <span class="text-lg font-bold text-zinc-800 dark:text-zinc-200 group-hover:text-zinc-500 transition-colors">
              {faq.question}
            </span>
            <div class="faq-icon-wrapper shrink-0 w-8 h-8 rounded-full bg-white dark:bg-zinc-800 flex items-center justify-center border border-zinc-200 dark:border-zinc-700 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="faq-icon transition-transform duration-300">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
          </button>
          <div class="faq-content max-h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out">
            <div class="px-6 md:px-8 pb-8 text-zinc-600 dark:text-zinc-400 leading-relaxed font-medium">
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');
  
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const parent = trigger.closest('.faq-item');
      const content = parent?.querySelector('.faq-content') as HTMLElement;
      const icon = parent?.querySelector('.faq-icon');
      const iconWrapper = parent?.querySelector('.faq-icon-wrapper');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Toggle current FAQ
      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        content.style.maxHeight = '0';
        content.style.opacity = '0';
        icon?.classList.remove('rotate-180');
        iconWrapper?.classList.remove('bg-indigo-500', 'border-indigo-500', 'text-white');
        parent?.classList.remove('border-indigo-500/50', 'bg-white', 'dark:bg-zinc-900');
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = content.scrollHeight + 'px';
        content.style.opacity = '1';
        icon?.classList.add('rotate-180');
        iconWrapper?.classList.add('bg-indigo-500', 'border-indigo-500', 'text-white');
        parent?.classList.add('border-indigo-500/50', 'bg-white', 'dark:bg-zinc-900');
      }
    });
  });
</script>
