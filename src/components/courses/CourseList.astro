<div id="course-list-container" class="max-w-6xl mx-auto py-16 lg:py-24 relative min-h-[500px]">
  
  <div id="course-loading" class="flex flex-col gap-16">
    {Array.from({ length: 3 }).map(() => (
      <div class="flex flex-col gap-8 p-6 lg:p-10 bg-zinc-50 dark:bg-zinc-900/50 rounded-[3rem] border border-zinc-200 dark:border-zinc-800 animate-pulse">
        <div class="w-full h-[300px] lg:h-[500px] bg-zinc-200 dark:bg-zinc-800 rounded-4xl shrink-0"></div>
        <div class="w-full flex flex-col justify-center">
          <div class="h-10 bg-zinc-200 dark:bg-zinc-800 rounded-md w-3/4 mb-6"></div>
          <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded-md w-full mb-3"></div>
          <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded-md w-[90%] mb-10"></div>
          <div class="mt-auto flex justify-between items-end border-t border-zinc-200 dark:border-zinc-800 pt-8">
            <div class="h-12 bg-zinc-200 dark:bg-zinc-800 rounded-md w-40"></div>
            <div class="h-14 bg-zinc-200 dark:bg-zinc-800 rounded-xl w-48"></div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div id="course-error" class="hidden text-center py-20 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[3rem] max-w-6xl mx-auto">
    <div class="w-20 h-20 bg-zinc-200 dark:bg-zinc-800 text-zinc-900 dark:text-white rounded-full flex items-center justify-center mx-auto mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
    </div>
    <h3 class="text-2xl max-w-80 lg:w-full mx-auto font-bold text-zinc-900 dark:text-white mb-2">Oops! Something went wrong.</h3>
    <p class="text-zinc-600 dark:text-zinc-400 mb-8" id="course-error-message">Failed to load courses. Please try again.</p>
    <button id="course-retry-btn" class="px-8 py-4 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-bold rounded-xl hover:scale-105 transition-transform duration-500 cursor-pointer">
      Retry Fetching
    </button>
  </div>

  <div id="course-grid" class="flex flex-col gap-16">
  </div>

  <div id="course-load-more-container" class="hidden text-center mt-20">
    <button id="course-load-more-btn" class="px-12 py-5 bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-white font-bold text-lg rounded-2xl border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors cursor-pointer">
      View More Courses
    </button>
  </div>
</div>

<script>
  import { API_URL } from "@/lib/constants";

  let allCourses: any[] = [];
  let displayedCount = 0;
  const ITEMS_PER_PAGE = 3; 

  // DOM Elements declared with types, initialized inside DOMContentLoaded
  let loadingEl: HTMLElement | null = null;
  let errorEl: HTMLElement | null = null;
  let errorMessageEl: HTMLElement | null = null;
  let gridEl: HTMLElement | null = null;
  let loadMoreContainer: HTMLElement | null = null;
  let loadMoreBtn: HTMLElement | null = null;
  let retryBtn: HTMLElement | null = null;

  function renderCourseCard(course: any) {
    const price = Number(course.price) === 0 ? 'Free' : '₹' + course.price;
    const originalPrice = course.original_price ? `<span class="line-through text-zinc-400 font-medium text-xl ml-4">₹${course.original_price}</span>` : '';
    const discountLabel = course.discount_label ? `<span class="px-3 py-1.5 bg-red-500 text-white text-xs font-black uppercase tracking-wider rounded-lg ml-4 translate-y-[-2px]">${course.discount_label}</span>` : '';
    const thumbnail = course.thumbnail_url || 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1600&q=80';
    const category = course.category || 'Masterclass';
    const description = course.description || 'Master the essential skills you need to elevate your career and personal growth with this comprehensive program designed by industry experts.';

    // Validity Logic
    let validityText = 'Lifetime Access';
    if (course.validity_days && course.validity_days < 30000) {
      if (course.validity_days % 365 === 0) {
        const years = course.validity_days / 365;
        validityText = `${years} ${years === 1 ? 'Year' : 'Years'} Access`;
      } else {
        validityText = `${course.validity_days} Days Access`;
      }
    }

    // Safely handle quotes in attributes
    const safeTitle = course.title ? course.title.replace(/"/g, '&quot;') : 'Course';

    return `
      <div class="group flex flex-col gap-8 lg:gap-10 p-6 lg:p-10 bg-zinc-50 dark:bg-zinc-950 rounded-[3rem] lg:rounded-[4rem] border border-zinc-200 dark:border-zinc-800 transition-colors hover:border-zinc-300 dark:hover:border-zinc-700">
        
        <div class="w-full shrink-0 relative rounded-3xl lg:rounded-[2.5rem] overflow-hidden bg-zinc-100 dark:bg-zinc-900 h-[220px] md:h-[400px] lg:h-[500px]">
          <img src="${thumbnail}" alt="${safeTitle}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          <div class="absolute top-6 left-6">
            <span class="px-5 py-2 bg-zinc-900 text-white dark:bg-white dark:text-zinc-900 text-xs font-bold uppercase tracking-wider rounded-xl shadow-lg">
              ${category}
            </span>
          </div>
        </div>

        <div class="w-full flex flex-col py-2">
          <h3 class="text-4xl lg:text-5xl font-black text-zinc-900 dark:text-white mb-6 leading-[1.1] tracking-tight wrap-break-word">
            ${course.title}
          </h3>
          
          <div class="mb-8 max-w-5xl">
            <div class="text-zinc-600 dark:text-zinc-400 text-lg lg:text-xl leading-relaxed font-medium">
              <span class="short-desc line-clamp-2 wrap-break-word">${description}</span>
              <span class="full-desc hidden wrap-break-word">${description}</span>
            </div>
            <button class="toggle-desc-btn text-red-500 font-bold text-sm uppercase tracking-wider mt-4 hover:underline cursor-pointer">
              Read More
            </button>
          </div>

          <div class="flex flex-wrap gap-4 mb-10">
            <div class="flex items-center gap-2 text-sm font-bold text-zinc-900 dark:text-zinc-300 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 px-5 py-2.5 rounded-xl">
              <svg class="text-red-500 w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              ${validityText}
            </div>
            <div class="flex items-center gap-2 text-sm font-bold text-zinc-900 dark:text-zinc-300 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 px-5 py-2.5 rounded-xl">
              <svg class="text-red-500 w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Master Mentor Guidance
            </div>
          </div>

          <div class="mt-auto pt-10 border-t border-zinc-200 dark:border-zinc-800 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
            <div class="flex items-end flex-wrap">
              <span class="text-5xl font-black text-zinc-900 dark:text-white tracking-tight">${price}</span>
              ${originalPrice}
              ${discountLabel}
            </div>
            <a href="/courses/${course.slug}" class="w-full md:w-auto px-12 py-5 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-bold text-lg rounded-2xl flex items-center justify-center gap-3 transition-transform duration-300 hover:scale-105 active:scale-95 cursor-pointer">
              Enroll Now
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    `;
  }

  function displayMore() {
    if (!gridEl) return;
    
    const nextBatch = allCourses.slice(displayedCount, displayedCount + ITEMS_PER_PAGE);
    
    nextBatch.forEach((course: any) => {
      gridEl?.insertAdjacentHTML('beforeend', renderCourseCard(course));
    });

    displayedCount += nextBatch.length;

    if (displayedCount >= allCourses.length) {
      loadMoreContainer?.classList.add('hidden');
    } else {
      loadMoreContainer?.classList.remove('hidden');
    }
  }

  async function fetchCourses() {
    try {
      loadingEl?.classList.remove('hidden');
      errorEl?.classList.add('hidden');
      gridEl?.classList.add('hidden');
      loadMoreContainer?.classList.add('hidden');
      if (gridEl) gridEl.innerHTML = '';
      displayedCount = 0;

      const response = await fetch(`${API_URL}/courses`);
      
      if (!response.ok) throw new Error('Failed to fetch courses');
      
      const resData = await response.json();
      
      if (resData.success === false) {
        throw new Error(resData.error?.message || 'Failed to fetch courses');
      }

      allCourses = resData.data || resData || [];

      loadingEl?.classList.add('hidden');
      
      if (allCourses.length === 0) {
        errorEl?.classList.remove('hidden');
        if (errorMessageEl) errorMessageEl.textContent = "No courses available at the moment. Please check back later.";
        retryBtn?.classList.add('hidden');
        return;
      }

      gridEl?.classList.remove('hidden');
      displayMore();

    } catch (err: any) {
      console.error(err);
      loadingEl?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      if (errorMessageEl) errorMessageEl.textContent = err.message || "Could not connect to the server. Please try again.";
      retryBtn?.classList.remove('hidden');
    }
  }

  // Execute on load - Prevents Null Element Errors
  document.addEventListener('DOMContentLoaded', () => {
    loadingEl = document.getElementById('course-loading');
    errorEl = document.getElementById('course-error');
    errorMessageEl = document.getElementById('course-error-message');
    gridEl = document.getElementById('course-grid');
    loadMoreContainer = document.getElementById('course-load-more-container');
    loadMoreBtn = document.getElementById('course-load-more-btn');
    retryBtn = document.getElementById('course-retry-btn');

    // Event Delegation for Read More / Hide Buttons
    if (gridEl) {
      gridEl.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.toggle-desc-btn');
        if (!btn) return;

        const container = btn.parentElement;
        if (!container) return;

        const shortDesc = container.querySelector('.short-desc');
        const fullDesc = container.querySelector('.full-desc');

        if (fullDesc?.classList.contains('hidden')) {
          // Expand
          fullDesc.classList.remove('hidden');
          shortDesc?.classList.add('hidden');
          btn.textContent = 'Hide Details';
        } else {
          // Collapse
          fullDesc?.classList.add('hidden');
          shortDesc?.classList.remove('hidden');
          btn.textContent = 'Read More';
        }
      });
    }

    if (retryBtn) retryBtn.addEventListener('click', fetchCourses);
    if (loadMoreBtn) loadMoreBtn.addEventListener('click', displayMore);

    fetchCourses();
  });
</script>