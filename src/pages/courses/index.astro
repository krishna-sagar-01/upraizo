---
import Layout from "@layouts/Layout.astro";
import CourseList from "@components/courses/CourseList.astro";
import FinalCTA from "@components/home/FinalCTA.astro";
---

<Layout 
  title="All Courses - Upraizo"
  description="Explore our masterclasses designed to elevate your soft skills, leadership, and personal growth."
>
  <section class="relative pt-16 pb-16 lg:pt-30 lg:pb-24 border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
      
      <div class="inline-flex items-center justify-center px-5 py-2.5 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 text-xs font-bold uppercase tracking-[0.2em] mb-10">
        Our Catalog
      </div>
      
      <h1 class="text-5xl lg:text-7xl font-black text-zinc-900 dark:text-white mb-6 tracking-tight leading-tight">
        Master Learning for <br />
        <span class="text-red-500 italic">Real Growth.</span>
      </h1>
      
      <p class="max-w-2xl mx-auto text-lg text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed">
        Browse our collection of premium courses. Each program is designed by master mentors to deliver practical results and accelerate your career.
      </p>
    </div>
  </section>

  <CourseList />
  
  <FinalCTA />
</Layout>