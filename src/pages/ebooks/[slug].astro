---
import Layout from "@layouts/Layout.astro";

// Use getStaticPaths for SSG so the build doesn't fail, but we'll fetch real data on client.
export async function getStaticPaths() {
  try {
    const API_URL =
      import.meta.env.VITE_API_BASE_URL || "http://localhost:8080/api/v1";
    const res = await fetch(`${API_URL}/ebooks`);
    const json = await res.json();
    const ebooks = json.data || json || [];
    return ebooks.map((e: any) => ({
      params: { slug: e.slug },
    }));
  } catch (error) {
    console.error("Failed to fetch ebooks for getStaticPaths:", error);
    return [{ params: { slug: "fallback-ebook" } }];
  }
}

const { slug } = Astro.params;
---

<Layout
  title={`E-book Details - Upraizo`}
  description="Master this digital guide and elevate your career."
>
  <div id="ebook-detail-container" class="min-h-screen pb-24" data-slug={slug}>
    <div
      id="ed-loading"
      class="max-w-7xl mx-auto pt-24 lg:pt-32 px-4 animate-pulse flex flex-col lg:flex-row gap-12 lg:gap-16"
    >
      <div class="w-full lg:w-[40%] shrink-0">
        <div
          class="w-full h-[400px] lg:h-[600px] bg-zinc-200 dark:bg-zinc-800 rounded-[3rem] lg:rounded-[4rem]"
        >
        </div>
      </div>
      <div class="w-full lg:w-[60%] flex flex-col pt-4">
        <div class="h-6 bg-zinc-200 dark:bg-zinc-800 rounded-md w-32 mb-8">
        </div>
        <div class="h-14 bg-zinc-200 dark:bg-zinc-800 rounded-xl w-3/4 mb-6">
        </div>
        <div class="h-6 bg-zinc-200 dark:bg-zinc-800 rounded-md w-full mb-4">
        </div>
        <div class="h-6 bg-zinc-200 dark:bg-zinc-800 rounded-md w-5/6 mb-12">
        </div>
        <div
          class="w-full h-[300px] bg-zinc-200 dark:bg-zinc-800 rounded-[3rem] mb-12"
        >
        </div>
      </div>
    </div>

    <div id="ed-error" class="hidden max-w-2xl mx-auto px-6 pt-48 text-center">
      <div
        class="w-24 h-24 bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 rounded-full flex items-center justify-center mx-auto mb-8 border border-zinc-200 dark:border-zinc-800"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="10"></circle><line
            x1="12"
            x2="12"
            y1="8"
            y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line></svg
        >
      </div>
      <h3 class="text-3xl font-black text-zinc-900 dark:text-white mb-4">
        Failed to load e-book
      </h3>
      <p
        class="text-zinc-600 dark:text-zinc-400 text-lg mb-10"
        id="ed-error-message"
      >
        We couldn't connect to the server.
      </p>
      <button
        id="ed-retry-btn"
        class="px-10 py-4 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-bold rounded-2xl hover:scale-105 transition-transform cursor-pointer"
      >
        Retry Fetching
      </button>
      <a
        href="/ebooks"
        class="block mt-6 text-zinc-500 dark:text-zinc-400 font-bold hover:text-zinc-900 dark:hover:text-white transition-colors"
      >
        &larr; Back to all e-books
      </a>
    </div>

    <div id="ed-content" class="hidden max-w-6xl mx-auto pt-10 lg:pt-16">
    </div>
  </div>
</Layout>

<script>
  import { API_URL } from "@/lib/constants";

  let container: HTMLElement | null = null;
  let loadingEl: HTMLElement | null = null;
  let errorEl: HTMLElement | null = null;
  let errorMessageEl: HTMLElement | null = null;
  let contentEl: HTMLElement | null = null;
  let retryBtn: HTMLElement | null = null;
  let slug: string | null | undefined = null;

  function renderEbook(ebook: any) {
    const price = Number(ebook.price) === 0 ? "Free" : "₹" + ebook.price;
    const originalPrice = ebook.original_price
      ? `<span class="line-through text-zinc-400 text-xl ml-3 font-medium">₹${ebook.original_price}</span>`
      : "";
    const discountLabel = ebook.discount_label
      ? `<span class="px-3 py-1 bg-red-500 text-white text-xs font-black uppercase tracking-wider rounded-lg ml-4 translate-y-[-2px] inline-block">${ebook.discount_label}</span>`
      : "";
    const thumbnail =
      ebook.thumbnail_url ||
      "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&w=1600&q=80";

    const description =
      ebook.description ||
      "Master your craft with this exclusive digital guide. Packed with actionable insights and professional strategies for high-performance growth.";

    // Safely handle quotes in attributes
    const safeTitle = ebook.title ? ebook.title.replace(/"/g, '&quot;') : 'Untitled E-book';

    return `
      <div class="mb-8 lg:mb-12">
        <a href="/ebooks" class="inline-flex items-center gap-2 text-zinc-500 dark:text-zinc-400 font-bold transition-colors hover:text-zinc-900 dark:hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back to Catalog
        </a>
      </div>

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 relative items-start">
        
        <div class="w-full lg:w-[40%] shrink-0">
          <div class="sticky top-10 w-full h-[400px] lg:h-[650px] rounded-[3rem] lg:rounded-[4rem] overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 shadow-2xl">
            <img src="${thumbnail}" alt="${safeTitle}" class="w-full h-full object-cover" />
          </div>
        </div>

        <div class="w-full lg:w-[60%] flex flex-col pb-10">
          
          <div class="mb-12">
            <span class="inline-block px-5 py-2 bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-white text-xs font-bold uppercase tracking-[0.2em] rounded-full mb-6">
              Digital Publication
            </span>
            
            <h1 class="text-4xl lg:text-6xl font-black text-zinc-900 dark:text-white mb-8 tracking-tight leading-[1.1] wrap-break-word">
              ${ebook.title || "Untitled E-book"}
            </h1>
            
            <div class="text-lg lg:text-xl text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed">
              <div class="desc-content">
                <span class="short-desc line-clamp-3 wrap-break-word">${description}</span>
                <span class="full-desc hidden wrap-break-word">${description}</span>
              </div>
              <button class="toggle-desc-btn text-red-500 font-bold text-sm uppercase tracking-wider mt-4 hover:underline cursor-pointer">
                Read More
              </button>
            </div>
          </div>

          <div class="p-8 lg:p-10 rounded-[3rem] bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 mb-16">
            <h3 class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-[0.2em] mb-4">Ownership</h3>
            
            <div class="flex items-center flex-wrap mb-10 pb-8 border-b border-zinc-200 dark:border-zinc-800">
              <span class="text-5xl font-black text-zinc-900 dark:text-white tracking-tight">${price}</span>
              ${originalPrice}
              ${discountLabel}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10">
              <div class="flex items-center gap-4 text-zinc-700 dark:text-zinc-300 font-bold">
                <svg class="text-red-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                <span>Full Digital Download</span>
              </div>
              <div class="flex items-center gap-4 text-zinc-700 dark:text-zinc-300 font-bold">
                <svg class="text-red-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                <span>Lifetime Library Access</span>
              </div>
              <div class="flex items-center gap-4 text-zinc-700 dark:text-zinc-300 font-bold">
                <svg class="text-red-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                <span>Future Updates Included</span>
              </div>
            </div>

            <a href="https://app.upraizo.com/auth/register" class="w-full py-5 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-bold text-lg rounded-2xl hover:scale-105 active:scale-95 transition-transform duration-500 flex items-center justify-center gap-3">
              Purchase E-book Now
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <p class="text-center text-xs font-bold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mt-6 flex items-center justify-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              100% Secure Checkout
            </p>
          </div>

            <section>
              <h2 class="text-3xl font-black text-zinc-900 dark:text-white mb-8 tracking-tight">What's Inside</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="p-8 bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-3xl">
                  <div class="w-12 h-12 bg-red-500 text-white rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-red-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M8 6h9"/><path d="M8 10h9"/><path d="M8 14h9"/></svg>
                  </div>
                  <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2">High Quality PDF</h3>
                  <p class="text-zinc-500 font-medium">Crystal clear reading experience on any device, from smartphones to desktops.</p>
                </div>
                <div class="p-8 bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-3xl">
                  <div class="w-12 h-12 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 rounded-2xl flex items-center justify-center mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><path d="m16 6-4 4-4-4"/><path d="M2 15h20"/><path d="M5 20h14"/><path d="M2 11h20"/></svg>
                  </div>
                  <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2">Instant Access</h3>
                  <p class="text-zinc-500 font-medium">Download your copy immediately after checkout and start learning today.</p>
                </div>
              </div>
            </section>
        </div>
      </div>
    `;
  }

  async function fetchEbookDetails() {
    if (!slug) return;

    try {
      loadingEl?.classList.remove("hidden");
      errorEl?.classList.add("hidden");
      contentEl?.classList.add("hidden");

      const detailRes = await fetch(`${API_URL}/ebooks/${slug}`);
      if (!detailRes.ok) throw new Error("Failed to fetch e-book details");
      const detailData = await detailRes.json();

      if (detailData.success === false) {
        throw new Error(detailData.error?.message || "E-book not found");
      }
      const ebook = detailData.data || detailData;

      if (contentEl) contentEl.innerHTML = renderEbook(ebook);

      loadingEl?.classList.add("hidden");
      contentEl?.classList.remove("hidden");
    } catch (err: any) {
      console.error(err);
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      if (errorMessageEl)
        errorMessageEl.textContent =
          err.message || "Failed to load e-book details. Please try again.";
    }
  }

  // Initialize logic after DOM is fully loaded to prevent null reference bugs
  document.addEventListener("DOMContentLoaded", () => {
    container = document.getElementById("ebook-detail-container");
    loadingEl = document.getElementById("ed-loading");
    errorEl = document.getElementById("ed-error");
    errorMessageEl = document.getElementById("ed-error-message");
    contentEl = document.getElementById("ed-content");
    retryBtn = document.getElementById("ed-retry-btn");

    slug = container?.getAttribute("data-slug");

    // Event Delegation for "Read More" button
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".toggle-desc-btn");
      if (!btn) return;

      const btnContainer = btn.parentElement;
      if (!btnContainer) return;

      const shortDesc = btnContainer.querySelector(".short-desc");
      const fullDesc = btnContainer.querySelector(".full-desc");

      if (fullDesc?.classList.contains("hidden")) {
        fullDesc.classList.remove("hidden");
        shortDesc?.classList.add("hidden");
        btn.textContent = "Hide Details";
      } else {
        fullDesc?.classList.add("hidden");
        shortDesc?.classList.remove("hidden");
        btn.textContent = "Read More";
      }
    });

    if (retryBtn) retryBtn.addEventListener("click", fetchEbookDetails);

    fetchEbookDetails();
  });
</script>