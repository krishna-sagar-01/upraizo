---
import Layout from "@layouts/Layout.astro";
import FinalCTA from "@components/home/FinalCTA.astro";
---

<Layout 
  title="About Us - Upraizo"
  description="Discover the story behind Upraizo, our mission, and the master mentors dedicated to your personal growth."
>
  <section class="relative pt-16 pb-20 lg:pt-30 lg:pb-32 overflow-hidden">    
    <div class="max-w-6xl mx-auto relative z-10 text-center">
      <div class="inline-flex items-center justify-center px-5 py-2.5 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 text-xs font-bold uppercase tracking-[0.2em] mb-10">
        Our Story
      </div>

      <h1 class="text-5xl lg:text-8xl font-black text-zinc-900 dark:text-white mb-8 tracking-tight leading-[1.1]">
        Where Real <br />
        <span class="text-red-600">Learning Begins.</span>
      </h1>
      
      <p class="max-w-2xl mx-auto text-xl text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed">
        We believe the standard education system is broken. It teaches you how to pass exams, but not how to win in life. Upraizo was built to fix that.
      </p>
    </div>
  </section>

  <section class="py-24 border-y border-zinc-200 dark:border-zinc-800 cursor-default">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        
        <div class="space-y-8">
          <h2 class="text-4xl lg:text-5xl font-black text-zinc-900 dark:text-white tracking-tight leading-[1.1]">
            More than just courses. <br />
            A <span class="text-red-600">movement.</span>
          </h2>
          <div class="space-y-6 text-lg text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed">
            <p>
              When we started Upraizo, we noticed a massive gap in the market. Millions of people had technical degrees, but lacked the basic soft skills needed to communicate their value, lead teams, or negotiate their worth.
            </p>
            <p>
              Traditional universities ignore these skills. Other online platforms treat them as an afterthought, offering boring, theoretical slideshows. 
            </p>
            <p class="font-bold text-zinc-900 dark:text-zinc-200 border-l-4 border-red-500 pl-5 py-2 bg-zinc-50 dark:bg-zinc-900/50 rounded-r-lg">
              We decided to build the ultimate platform for real-world growth. Driven by master mentors who have actually achieved what they teach.
            </p>
          </div>
        </div>
        
        <div class="w-full aspect-square lg:aspect-4/3 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[3rem] flex items-center justify-center p-10 overflow-hidden">
          <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full max-w-sm">
            <path d="M50 0V400M150 0V400M250 0V400M350 0V400" stroke="currentColor" class="text-zinc-200 dark:text-zinc-800" stroke-width="1" stroke-dasharray="4 4"/>
            <path d="M0 50H400M0 150H400M0 250H400M0 350H400" stroke="currentColor" class="text-zinc-200 dark:text-zinc-800" stroke-width="1" stroke-dasharray="4 4"/>
            
            <rect x="60" y="260" width="80" height="80" rx="16" class="fill-zinc-200 dark:fill-zinc-800" />
            <rect x="160" y="160" width="80" height="180" rx="16" class="fill-zinc-300 dark:fill-zinc-700" />
            <rect x="260" y="60" width="80" height="280" rx="16" class="fill-red-500" />
            
            <path d="M100 230 L100 130 L200 130 L200 30 L300 30" stroke="currentColor" class="text-zinc-900 dark:text-zinc-100" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M280 50 L300 30 L320 50" stroke="currentColor" class="text-zinc-900 dark:text-zinc-100" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 cursor-default">
    <div class="max-w-6xl mx-auto">
      
      <div class="text-center mb-20">
        <h2 class="text-xs font-black text-zinc-500 dark:text-zinc-400 uppercase tracking-[0.3em] mb-4">Our DNA</h2>
        <h3 class="text-4xl lg:text-5xl font-black text-zinc-900 dark:text-white tracking-tight">Core Values</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: "Radical Excellence",
            desc: "We don't settle for 'good enough'. Every module, every video, and every resource is crafted to the highest standard possible.",
            icon: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />',
          },
          {
            title: "Practical Action",
            desc: "Theory is useless without execution. Our curriculum is 100% focused on actionable steps that you can implement immediately.",
            icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />',
          },
          {
            title: "True Mentorship",
            desc: "We don't just sell videos. We provide a path. Our master mentors are committed to guiding you through your transformation.",
            icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M9 11v10"/>',
          }
        ].map(value => (
          <div class="p-10 rounded-[3rem] bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 transition-transform duration-300 hover:-translate-y-2">
            
            <div class="w-16 h-16 rounded-3xl bg-zinc-200 dark:bg-zinc-800 text-zinc-900 dark:text-zinc-100 flex items-center justify-center mb-8">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={value.icon} />
            </div>
            
            <h4 class="text-2xl font-black text-zinc-900 dark:text-white mb-4">{value.title}</h4>
            <p class="text-zinc-600 dark:text-zinc-400 font-medium leading-relaxed">
              {value.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>