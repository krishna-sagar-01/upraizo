---
import Layout from "@layouts/Layout.astro";
import FinalCTA from "@components/home/FinalCTA.astro";

const reasons = [
  {
    title: "Master Mentor Approach",
    desc: "Unlike other platforms with hundreds of random teachers, here you learn directly from a single master mentor who has walked the path and achieved real success.",
    icon: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />'
  },
  {
    title: "Result-Driven Curriculum",
    desc: "We don't teach theory. Every module is designed to be actionable, helping you see real changes in your communication and confidence from day one.",
    icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />'
  },
  {
    title: "Focused on Soft Skills",
    desc: "In a world obsessed with technical skills, we focus on the human side—leadership, empathy, and influence—the real keys to high-level career growth.",
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" />'
  }
];
---

<Layout 
  title="Why Upraizo - Our Philosophy & Mission"
  description="Discover why Upraizo is the best platform for mastering soft skills. Learn about our unique master mentor approach and result-driven philosophy."
>
  <section class="relative pt-16 pb-20 lg:pt-30 lg:pb-32">
    <div class="max-w-6xl mx-auto relative z-10 text-center">
      
      <div class="inline-flex items-center justify-center px-5 py-2.5 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 text-xs font-bold uppercase tracking-[0.2em] mb-10">
        Our Mission
      </div>

      <h1 class="text-5xl lg:text-8xl font-black tracking-tight leading-[1.1] text-zinc-900 dark:text-white mb-8">
        Why we built <br />
        <span class="text-red-600">Upraizo.</span>
      </h1>

      <p class="max-w-2xl mx-auto text-lg lg:text-xl text-zinc-600 dark:text-zinc-400 mb-12 leading-relaxed font-medium">
        We realized that technical skills can get you the job, but soft skills get you the promotion. Upraizo was born to bridge this gap with high-quality, mentor-led education.
      </p>
    </div>
  </section>

  <section class="py-24 bg-zinc-50 dark:bg-zinc-900/30 border-y border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        
        <div class="w-full aspect-square bg-white dark:bg-black border border-zinc-200 dark:border-zinc-800 rounded-[3rem] flex items-center justify-center p-10 overflow-hidden relative">
          
          <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full max-w-md">
            <path d="M50 0V400M150 0V400M250 0V400M350 0V400" stroke="currentColor" class="text-zinc-100 dark:text-zinc-900" stroke-width="2" stroke-dasharray="4 4"/>
            <path d="M0 50H400M0 150H400M0 250H400M0 350H400" stroke="currentColor" class="text-zinc-100 dark:text-zinc-900" stroke-width="2" stroke-dasharray="4 4"/>

            <circle cx="200" cy="200" r="140" class="stroke-zinc-200 dark:stroke-zinc-800" stroke-width="2" />
            <circle cx="200" cy="200" r="90" class="stroke-zinc-300 dark:stroke-zinc-700" stroke-width="2" stroke-dasharray="8 8" />

            <circle cx="200" cy="200" r="45" class="fill-red-500" />
            <circle cx="200" cy="200" r="16" class="fill-white dark:fill-zinc-950" />

            <circle cx="100" cy="100" r="16" class="fill-zinc-900 dark:fill-zinc-100" />
            <path d="M110 110 L165 165" class="stroke-zinc-900 dark:stroke-zinc-100" stroke-width="4" stroke-linecap="round" />

            <circle cx="300" cy="100" r="16" class="fill-zinc-900 dark:fill-zinc-100" />
            <path d="M290 110 L235 165" class="stroke-zinc-900 dark:stroke-zinc-100" stroke-width="4" stroke-linecap="round" />

            <circle cx="100" cy="300" r="16" class="fill-zinc-900 dark:fill-zinc-100" />
            <path d="M110 290 L165 235" class="stroke-zinc-900 dark:stroke-zinc-100" stroke-width="4" stroke-linecap="round" />
          </svg>
        </div>
        
        <div class="space-y-6">
          {reasons.map((reason) => (
            <div class="p-8 rounded-[2.5rem] bg-white dark:bg-black border border-zinc-200 dark:border-zinc-800 transition-all duration-300 hover:border-zinc-300 dark:hover:border-zinc-700">
              <div class="flex gap-6 items-start">
                
                <div class="shrink-0 w-14 h-14 rounded-2xl bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 flex items-center justify-center mt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={reason.icon} />
                </div>
                
                <div>
                  <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2">{reason.title}</h3>
                  <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed font-medium">
                    {reason.desc}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-6xl mx-auto">
      <div class="bg-zinc-50 dark:bg-zinc-900 rounded-[3rem] p-12 lg:p-24 text-center border border-zinc-200 dark:border-zinc-800 flex flex-col items-center">
        
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="text-zinc-300 dark:text-zinc-700 mb-8">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
        </svg>

        <h2 class="text-3xl lg:text-5xl font-black text-zinc-900 dark:text-white mb-8 leading-[1.2] tracking-tight">
          "The greatest investment you can make is in yourself."
        </h2>
        
        <p class="text-red-500 text-sm font-bold uppercase tracking-[0.3em]">— Upraizo Philosophy</p>
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>