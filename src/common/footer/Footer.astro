---
import { Image } from "astro:assets";

// Updated Footer Navigation for Course Platform
const footerNav = [
  {
    title: "Explore",
    links: [
      { name: "All Courses", href: "/courses" },
      { name: "E-Books", href: "/ebooks" },
      { name: "Features", href: "/#features" },
      { name: "Why Upraizo", href: "/why-upraizo" },
    ],
  },
  {
    title: "Resources",
    links: [
      { name: "FAQ", href: "/#faq" },
      { name: "Help Center", href: "/contact" },
    ],
  },
  {
    title: "Company",
    links: [
      { name: "About Us", href: "/about" },
      { name: "Contact Us", href: "/contact" },
    ],
  },
];

const legalLinks = [
  { name: "Privacy Policy", href: "/legal/privacy-policy" },
  { name: "Terms of Service", href: "/legal/terms-of-service" },
];
---

<footer class="w-full border-t border-zinc-200 dark:border-zinc-800/80">
  <div class="mx-auto max-w-7xl py-16 px-5">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-12 mb-16">
      <!-- Brand Section -->
      <div class="col-span-2 pr-0 md:pr-12">
        <div class="mb-6 flex items-center gap-1">
          <Image
            class="w-12 h-12 object-contain"
            src="/favicon.svg"
            alt="Upraizo Logo"
            width={48}
            height={48}
            loading="lazy"
            decoding="async"
          />
          <h2 class="text-3xl font-black text-zinc-800 dark:text-zinc-200">
            Upraizo.
          </h2>
        </div>
        <p
          class="text-md text-zinc-600 dark:text-zinc-400 mb-6 max-w-sm leading-relaxed"
        >
          Master the art of communication, leadership, and personal growth.
          Upraizo helps you build the essential soft skills needed for a
          successful life and a flourishing career.
        </p>
      </div>

      <!-- Navigation Columns -->
      {
        footerNav.map((column) => (
          <div>
            <h3 class="text-xs font-black text-zinc-400 uppercase tracking-widest mb-6">
              {column.title}
            </h3>
            <ul class="space-y-4">
              {column.links.map((link) => (
                <li>
                  <a
                    aria-label={link.name}
                    href={link.href}
                    class="text-sm font-semibold text-zinc-600 dark:text-zinc-400 hover:text-indigo-500 dark:hover:text-indigo-500 transition-colors"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-zinc-200 dark:border-zinc-800/80">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <p
          class="text-sm text-zinc-500 dark:text-zinc-500"
          id="footer-copyright"
        >
          © {new Date().getFullYear()} Upraizo. All rights reserved.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
          {
            legalLinks.map((link) => (
              <a
                aria-label={link.name}
                href={link.href}
                class="text-sm font-semibold text-zinc-600 dark:text-zinc-400 hover:text-indigo-500 transition-colors"
              >
                {link.name}
              </a>
            ))
          }
          <span class="text-zinc-300 dark:text-zinc-700 hidden sm:inline"
            >•</span
          >
          <a
            aria-label="Email Support"
            href="mailto:support@upraizo.com"
            class="text-sm font-semibold text-zinc-600 dark:text-zinc-400 hover:text-indigo-500 transition-colors"
          >
            support@upraizo.com
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  // Dynamic Year Update
  const copyEl = document.getElementById("footer-copyright");
  if (copyEl) {
    copyEl.textContent = `© ${new Date().getFullYear()} Upraizo. All rights reserved.`;
  }
</script>
