---
import { Image } from "astro:assets";

// Navigation Data for Course Platform
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/courses", label: "Courses" },
  { href: "/ebooks", label: "E-books" },
  { href: "/why-upraizo", label: "Why Upraizo" },
  { href: "/about", label: "About Us" },
];
---

<div
  id="sidebarBackdrop"
  class="fixed inset-0 bg-zinc-950/40 backdrop-blur-md z-100 transition-opacity duration-500 md:hidden opacity-0 pointer-events-none"
>
</div>

<aside
  id="mobileSidebar"
  class="fixed top-0 left-0 h-full w-[80%] max-w-[320px] bg-zinc-50 dark:bg-zinc-900 z-101 border-r border-zinc-200 dark:border-zinc-800/50 transition-transform duration-500 ease-in-out md:hidden -translate-x-full"
>
  <div class="flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <div
      class="p-5 flex items-center justify-between border-b border-zinc-100 dark:border-zinc-800/50"
    >
      <div class="flex items-center gap-1">
        <Image 
          class="w-10 h-10 object-contain" 
          src="/favicon.svg" 
          alt="logo" 
          width={40} 
          height={40} 
          loading="lazy"
          decoding="async"
        />
        <h1 class="text-2xl font-black text-zinc-800 dark:text-zinc-200">
          Upraizo.
        </h1>
      </div>
      <button
        id="closeSidebarBtn"
        class="w-10 h-10 flex items-center justify-center rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-500"
        aria-label="Close sidebar"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Navigation Links -->
    <div class="flex-1 overflow-y-auto p-5 space-y-2">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            class="block p-3 text-lg font-bold text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800/50 rounded-2xl transition-all bg-zinc-100 dark:bg-zinc-800/50"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Bottom Actions -->
    <div class="p-5 border-t border-zinc-100 dark:border-zinc-800/50 space-y-3">
      <a
        href="https://app.upraizo.com/auth/login"
        class="block w-full py-3 text-center font-bold text-zinc-700 dark:text-zinc-200 bg-zinc-200 dark:bg-zinc-800 rounded-2xl"
      >
        Login
      </a>
      <a
        href="https://app.upraizo.com/auth/register"
        class="block w-full py-3 text-center font-bold text-zinc-100 dark:text-zinc-800 bg-zinc-800 dark:bg-zinc-100 rounded-2xl"
      >
        Get Started
      </a>
    </div>
  </div>
</aside>

<script>
  const mobileSidebar = document.getElementById("mobileSidebar");
  const sidebarBackdrop = document.getElementById("sidebarBackdrop");
  const closeSidebarBtn = document.getElementById("closeSidebarBtn");

  const toggleSidebar = () => {
    const isOpen = mobileSidebar?.classList.contains("translate-x-0");
    mobileSidebar?.classList.toggle("translate-x-0", !isOpen);
    mobileSidebar?.classList.toggle("-translate-x-full", isOpen);
    sidebarBackdrop?.classList.toggle("opacity-100", !isOpen);
    sidebarBackdrop?.classList.toggle("opacity-0", isOpen);
    sidebarBackdrop?.classList.toggle("pointer-events-none", isOpen);
    document.body.style.overflow = isOpen ? "" : "hidden";
  };

  window.addEventListener("toggle-mobile-menu", toggleSidebar);
  [sidebarBackdrop, closeSidebarBtn].forEach((el) =>
    el?.addEventListener("click", toggleSidebar),
  );

  // Close on link click
  document
    .querySelectorAll("#mobileSidebar a")
    .forEach((l) =>
      l.addEventListener("click", () => setTimeout(toggleSidebar, 200)),
    );

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      mobileSidebar?.classList.contains("translate-x-0")
    ) {
      toggleSidebar();
    }
  });
</script>
