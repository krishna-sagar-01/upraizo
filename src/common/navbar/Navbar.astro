---
import { Image } from "astro:assets";

// Navigation Links for Course Platform
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/courses", label: "Courses" },
  { href: "/ebooks", label: "E-books" },
  { href: "/why-upraizo", label: "Why Upraizo" },
  { href: "/about", label: "About Us" },
];
---

<div
  class="w-full p-1 h-12 sm:h-14 lg:h-13 rounded-full bg-zinc-100/50 dark:bg-zinc-900/50 backdrop-blur-md border border-zinc-200/50 dark:border-zinc-800/60 flex items-center justify-between relative navbar-container"
>
  <div
    onclick="window.location.href='/'"
    class="flex items-center gap-1 pl-1 cursor-pointer select-none"
  >
    <Image
      class="w-10 h-10 object-contain"
      src="/favicon.svg"
      alt="Upraizo Logo"
      width={40}
      height={40}
      loading="eager"
      decoding="async"
    />
    <h1 class="text-2xl font-black text-zinc-800 dark:text-zinc-200">
      Upraizo.
    </h1>
  </div>

  <!-- Desktop Navigation (Simplified - No Dropdowns) -->
  <div class="hidden md:flex items-center relative px-2 nav-items h-full">
    <div
      class="absolute rounded-full h-10 bg-zinc-200/70 dark:bg-zinc-800/80 transition-all duration-300 pointer-events-none sliding-pill opacity-0 w-0 left-0"
    >
    </div>

    {
      navLinks.map((link) => (
        <div class="relative nav-item h-full flex items-center">
          <a
            href={link.href}
            aria-label={link.label}
            class="px-5 h-full flex items-center justify-center text-md font-bold text-zinc-700 dark:text-zinc-300 transition-colors relative z-10 whitespace-nowrap"
          >
            {link.label}
          </a>
        </div>
      ))
    }
  </div>

  <!-- Action Buttons -->
  <div class="flex items-center gap-2 h-full">
    <a
      target="_blank"
      href="https://app.upraizo.com/auth/login"
      aria-label="Login"
      class="h-full flex items-center px-6 text-sm font-bold rounded-full transition-colors text-zinc-700 dark:text-zinc-200 bg-linear-to-r dark:from-zinc-800 dark:to-zinc-800/50 from-zinc-200 to-zinc-200/50"
    >
      Login
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      type="button"
      id="mobileMenuBtn"
      aria-label="Open navigation menu"
      class="flex items-center justify-center h-full px-4 rounded-full md:hidden bg-zinc-200/70 dark:bg-zinc-800/70"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="100%"
        height="100%"
        viewBox="0 0 20 20"
        fill="none"
        class="w-6 h-6"
      >
        <path
          fill="currentColor"
          fill-rule="evenodd"
          d="M3 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1h6a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Z"
          clip-rule="evenodd"></path>
      </svg>
    </button>

    <a
      target="_blank"
      href="https://app.upraizo.com/auth/register"
      aria-label="Get Started"
      class="h-full hidden md:flex items-center px-6 text-sm font-bold rounded-full transition-colors dark:text-zinc-800 text-zinc-100 bg-zinc-800 dark:bg-zinc-100"
    >
      Get Started
    </a>
  </div>
</div>

<script>
  const navItems = document.querySelectorAll<HTMLElement>(".nav-item");
  const slidingPill = document.querySelector<HTMLElement>(".sliding-pill");
  const navContainer = document.querySelector(".nav-items");

  navItems.forEach((item) => {
    item.addEventListener("mouseenter", () => {
      if (slidingPill) {
        // Offset settings for the sliding pill
        slidingPill.style.width = `${item.offsetWidth}px`;
        slidingPill.style.left = `${item.offsetLeft}px`;
        slidingPill.style.opacity = "1";
      }
    });
  });

  navContainer?.addEventListener("mouseleave", () => {
    if (slidingPill) slidingPill.style.opacity = "0";
  });

  document.getElementById("mobileMenuBtn")?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("toggle-mobile-menu"));
  });
</script>
